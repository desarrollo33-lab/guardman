---
// /404 — página no encontrada.
import BaseLayout from '../layouts/BaseLayout.astro';
import { NAV_LINKS } from '../lib/constants';
---

<BaseLayout title="Página no encontrada" description="La página que busca no existe o fue movida." noindex>
  <section class="not-found">
    <div class="container-narrow not-found-card">
      <div class="nf-code">404</div>
      <h1>Página no encontrada</h1>
      <p>La dirección que busca no existe o fue movida. Verifique la URL o vuelva al inicio del sitio.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/contacto" class="btn btn-ghost">Contactar soporte</a>
      </div>
      <div class="nf-links">
        <p>O explore estas secciones:</p>
        <div class="nf-link-list">
          {NAV_LINKS.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
