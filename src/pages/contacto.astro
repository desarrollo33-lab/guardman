---
// /contacto — formulario de contacto (migración 1:1 del live).
// v1.1 — usa <LeadForm> compartido con /cotizacion.
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { SITE } from '../lib/constants';

const services = [
  'Guardias de Seguridad',
  'CCTV y Videovigilancia',
  'Control de Accesos',
  'Monitoreo 24/7',
  'PPI (Protección de Personas Importantes)',
  'Guard Pod',
  'Seguridad Industrial',
  'Seguridad para Eventos',
  'Auditoría de Seguridad',
  'Aseo y Mantenimiento',
];

const leadFormSections = [
  {
    fields: [
      { name: 'name', label: 'Nombre completo', type: 'text' as const, required: true },
      { name: 'email', label: 'Correo electrónico', type: 'email' as const, required: true },
      { name: 'phone', label: 'Teléfono', type: 'tel' as const, required: true },
      { name: 'location', label: 'Comuna', type: 'text' as const },
      { name: 'service', label: 'Servicio de interés', type: 'select' as const, required: true, options: services, fullWidth: true },
      { name: 'message', label: 'Mensaje', type: 'textarea' as const, fullWidth: true, rows: 4 },
    ],
  },
];
---

<BaseLayout
  title="Contacto 24/7 GuardMan Chile Seguridad Privada"
  description="Contáctenos 24/7. Teléfono, correo electrónico y formulario. Hable con un experto en seguridad privada certificado OS-10. Respuesta garantizada en menos de 24 horas hábiles."
  breadcrumb="Contacto"
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Contacto', url: '/contacto' }]}
  showCluster={true}
  clusterType="servicios"
>
  <section class="hero" data-od-id="hero">
    <div class="container">
      <h1>Hablemos de su seguridad</h1>
      <p>Estamos disponibles <strong>24 horas, los 7 días de la semana</strong>. Respuesta garantizada en menos de 24 horas hábiles. Cotización sin compromiso y visita técnica gratuita a su propiedad.</p>
    </div>
  </section>

  <section class="bg-neutral" data-od-id="contacto-info">
    <div class="container section-grid">
      <div>
        <span class="section-label">Información de contacto</span>
        <h2 class="section-title">Estamos aquí para ayudarle</h2>
        <p style="color:var(--muted);margin-bottom:24px">Encuentre todos los canales para comunicarse con nuestro equipo comercial y de operaciones.</p>

        <div class="contact-info-card">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="contact-info-text">
            <h4>Teléfono</h4>
            <a href={`tel:${SITE.PHONE_TEL}`}>{SITE.PHONE}</a>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="contact-info-text">
            <h4>Email</h4>
            <a href={`mailto:${SITE.EMAIL_INFO}`}>{SITE.EMAIL_INFO}</a>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="contact-info-text">
            <h4>Dirección</h4>
            <p>{SITE.ADDRESS}</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="contact-info-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="contact-info-text">
            <h4>Horario</h4>
            <p>Lunes a Domingo: 24 horas</p>
          </div>
        </div>
      </div>

      <div>
        <LeadForm
          id="contact-form"
          title="Envíenos un mensaje"
          subtitle="Complete el formulario y le responderemos en menos de 24 horas hábiles."
          sections={leadFormSections}
          submitText="Enviar mensaje"
          trackName="contacto"
          successRedirect="/gracias"
        />

        <div style="margin-top:24px;padding:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);text-align:center">
          <p style="font-size:14px;color:var(--muted);margin-bottom:12px"><strong>Encuéntranos</strong></p>
          <p style="font-size:14px;color:var(--primary)">{SITE.ADDRESS}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-dark" style="text-align:center;padding:80px 0" data-od-id="cta">
    <div class="container">
      <h2 class="section-title" style="color:#fff">¿Prefiere que le llamemos?</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,.7);max-width:500px;margin:0 auto 28px">Solicite una cotización sin compromiso y descubra por qué cientos de empresas e instituciones confían en GuardMan Chile para proteger lo que más les importa.</p>
      <a href="/cotizacion" class="btn btn-primary btn-lg">Solicitar cotización</a>
    </div>
  </section>
</BaseLayout>