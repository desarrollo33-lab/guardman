---
// /privacidad — Política de Privacidad v4.1
// Marco legal aplicable:
//   - Ley 19.628 sobre Protección de la Vida Privada (Chile, vigente desde 1999).
//   - D.S. N° 83/2005 — Reglamento de la Ley 19.628.
//   - Ley 20.575 — Principios sobre probidad y transparencia (cookies, etc.).
// Migrado al sistema de diseño: hero con badge, layout 2-col con TOC
// sticky, cards de derechos, FAQ schema, privacy schema, breadcrumb.
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/constants';
import Icon from '../components/Icon.astro';
import LeadCTA from '../components/LeadCTA.astro';

const lastUpdated = '2026-07-15';
const lastUpdatedHuman = '15 de julio de 2026';
const effectiveDate = '2026-07-22';

const sections = [
  {
    id: 'informacion-que-recopilamos',
    num: '01',
    icon: 'database' as const,
    title: 'Información que recopilamos',
    intro: 'Recopilamos solo los datos necesarios para prestar el servicio que contratas o el que nos solicitas.',
    blocks: [
      { kind: 'kv', label: 'Datos de contacto', value: 'nombre, correo electrónico, número de teléfono, dirección.' },
      { kind: 'kv', label: 'Datos comerciales', value: 'empresa, cargo, tipo de propiedad, necesidades de seguridad.' },
      { kind: 'kv', label: 'Datos técnicos', value: 'dirección IP, tipo de navegador, páginas visitadas, tiempo de navegación.' },
      { kind: 'kv', label: 'Datos de cotización', value: 'detalles específicos sobre los servicios de seguridad solicitados.' },
    ],
  },
  {
    id: 'como-usamos',
    num: '02',
    icon: 'settings' as const,
    title: 'Cómo utilizamos tu información',
    intro: 'El uso está limitado a las finalidades declaradas en esta política. No vendemos ni alquilamos datos personales.',
    list: [
      'Procesar y responder a tus consultas y solicitudes enviadas desde el sitio.',
      'Gestionar cotizaciones que nos solicites a través de los formularios del sitio.',
      'Enviar comunicaciones relacionadas con tu solicitud o consulta.',
      'Cumplir con obligaciones legales y regulatorias aplicables en Chile.',
      'Mejorar la experiencia de usuario en nuestro sitio web.',
    ],
  },
  {
    id: 'proteccion',
    num: '03',
    icon: 'shield' as const,
    title: 'Protección de datos',
    intro: 'Aplicamos medidas técnicas y organizativas para resguardar tu información contra acceso no autorizado, alteración, divulgación o destrucción.',
    list: [
      'Cifrado TLS 1.3 en tránsito y AES-256 en reposo.',
      'Firewalls, control de acceso por rol y registro de auditoría.',
      'Backups cifrados con retención limitada.',
      'Personal con acuerdo de confidencialidad y capacitación periódica.',
    ],
  },
  {
    id: 'comparticion',
    num: '04',
    icon: 'users' as const,
    title: 'Compartición de información',
    intro: 'Sólo compartimos información personal en los siguientes casos:',
    list: [
      'Con proveedores de servicios que nos asisten en nuestras operaciones, bajo acuerdos de confidencialidad.',
      'Cuando sea requerido por ley o por orden de autoridad competente (tribunales, Ministerio Público, Carabineros, PDI).',
      'Para proteger los derechos, propiedad o seguridad de GuardMan Chile, nuestros clientes o el público.',
    ],
    note: 'Nunca vendemos, alquilamos ni comercializamos tu información personal.',
  },
  {
    id: 'cookies',
    num: '05',
    icon: 'eye' as const,
    title: 'Cookies y tecnologías similares',
    intro: 'Usamos cookies para mejorar la navegación, analizar tráfico y personalizar contenido. Puedes rechazar las cookies no esenciales desde el banner de consentimiento.',
    table: {
      headers: ['Tipo', 'Finalidad', 'Proveedor', 'Duración'],
      rows: [
        ['Esenciales', 'Sesión, seguridad, equilibrio de carga', 'GuardMan Chile', 'Sesión'],
        ['Analítica (opcional)', 'Métricas agregadas de uso del sitio', 'Google Analytics / Plausible', 'Hasta 24 meses'],
        ['Marketing (opcional)', 'Sin uso actualmente', '—', '—'],
      ],
    },
  },
  {
    id: 'derechos',
    num: '06',
    icon: 'scale' as const,
    title: 'Tus derechos',
    intro: 'Conforme a la Ley 19.628 y sus reglamentos, tienes los siguientes derechos sobre tus datos personales:',
  },
  {
    id: 'cambios',
    num: '07',
    icon: 'flag' as const,
    title: 'Cambios a esta política',
    intro: 'Podemos actualizar esta política periódicamente para reflejar cambios legales, técnicos o de operación.',
    note: 'Cuando un cambio sea sustancial, lo notificaremos mediante un aviso visible en el sitio y, cuando proceda, por correo electrónico.',
  },
];

const derechos = [
  {
    icon: 'eye' as const,
    title: 'Acceso',
    desc: 'Conocer qué datos personales tenemos sobre ti y cómo los tratamos.',
  },
  {
    icon: 'edit' as const,
    title: 'Rectificación',
    desc: 'Solicitar la corrección de datos inexactos, incompletos o desactualizados.',
  },
  {
    icon: 'close' as const,
    title: 'Supresión / Cancelación',
    desc: 'Pedir la eliminación de tus datos cuando ya no sean necesarios para la finalidad declarada.',
  },
  {
    icon: 'shield' as const,
    title: 'Oposición',
    desc: 'Oponerte al tratamiento de tus datos para fines de marketing o cuando afecte tus derechos.',
  },
