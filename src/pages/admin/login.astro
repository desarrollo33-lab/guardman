---
// /admin/login — página de login (sin AdminLayout para evitar auth guard).
import '../../styles/global.css';
import { SITE } from '../../lib/constants';

const redirect = Astro.url.searchParams.get('redirect') ?? '/admin';
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso — GuardMan Admin</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body data-theme="dark" class="login-body">
    <form id="login-form" class="login-card">
      <div class="login-logo">
        <div class="shield">🛡️</div>
        <span>GuardMan Admin</span>
      </div>
      <h2>Bienvenido</h2>
      <p class="sub">Panel de Administración v2.1</p>

      <div id="login-error" class="login-error" hidden></div>

      <div class="login-field">
        <label for="email">Correo electrónico</label>
        <input id="email" type="email" name="email" value="admin@guardman.oficinadesarrollo33.workers.dev" required />
      </div>
      <div class="login-field">
        <label for="password">Contraseña</label>
        <input id="password" type="password" name="password" placeholder="••••••••" required />
      </div>

      <button type="submit" id="login-btn" class="login-btn">
        <span id="login-btn-text">Iniciar Sesión</span>
      </button>

      <div class="login-cert">
        <span class="cert-badge">OS-10 Autorizado</span>
      </div>
    </form>

    <script is:inline define:vars={{ redirect, apiUrl: SITE.API_URL }}>
      // ════════════════════════════════════════════════════════════
      // Client-side rate limit: 5 attempts per minute, sliding window.
      // Persists across sessions; clears on success.
      // ════════════════════════════════════════════════════════════
      const ATTEMPTS_KEY = 'gm_login_attempts';
      const MAX_ATTEMPTS = 5;
      const WINDOW_MS = 60_000;

      const readAttempts = () => {
        try {
          const raw = localStorage.getItem(ATTEMPTS_KEY);
          if (!raw) return [];
          const arr = JSON.parse(raw);
          return Array.isArray(arr) ? arr.filter((t) => Date.now() - t < WINDOW_MS) : [];
        } catch { return []; }
      };
      const writeAttempts = (arr) => {
        try { localStorage.setItem(ATTEMPTS_KEY, JSON.stringify(arr)); } catch {}
      };
      const clearAttempts = () => {
        try { localStorage.removeItem(ATTEMPTS_KEY); } catch {}
      };
      const isLocked = () => readAttempts().length >= MAX_ATTEMPTS;
      const lockSeconds = () => {
        const arr = readAttempts();
        if (!arr.length) return 0;
        const oldest = arr[0];
        const remaining = Math.ceil((WINDOW_MS - (Date.now() - oldest)) / 1000);
        return Math.max(remaining, 1);
      };

      const ACCESS_KEY = 'gm_token';
      const ACCESS_EXP = 'gm_token_expires_at';
      const REFRESH_KEY = 'gm_refresh_token';
      const REFRESH_EXP = 'gm_refresh_expires_at';
      const ACCESS_TTL = 2 * 60 * 60 * 1000;
      const REFRESH_TTL = 30 * 24 * 60 * 60 * 1000;

      const form = document.getElementById('login-form');
      const errBox = document.getElementById('login-error');
      const btn = document.getElementById('login-btn');
      const btnText = document.getElementById('login-btn-text');

      const showError = (msg) => {
        errBox.hidden = false;
        errBox.textContent = '⚠️ ' + msg;
      };

      const lockUI = () => {
        btn.disabled = true;
        btnText.textContent = 'Bloqueado — espera ' + lockSeconds() + 's';
      };

      // If already locked on load, disable the form
      if (isLocked()) {
        lockUI();
        showError('Demasiados intentos. Espera ' + lockSeconds() + 's antes de reintentar.');
        setInterval(() => {
          if (!isLocked()) {
            btn.disabled = false;
            btnText.textContent = 'Iniciar Sesión';
            errBox.hidden = true;
          } else {
            btnText.textContent = 'Bloqueado — espera ' + lockSeconds() + 's';
          }
        }, 1000);
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errBox.hidden = true;

        if (isLocked()) {
          showError('Demasiados intentos. Espera ' + lockSeconds() + 's.');
          return;
        }

        btn.disabled = true;
        btnText.innerHTML = '<span class="spinner"></span> Conectando...';

        try {
          const email = form.email.value;
          const password = form.password.value;
          const res = await fetch(`${apiUrl}/api/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password }),
          });
          const data = await res.json();
          if (!data.ok) {
            const attempts = readAttempts();
            attempts.push(Date.now());
            writeAttempts(attempts);
            if (isLocked()) { lockUI(); return; }
            throw new Error(data.error || 'Credenciales inválidas');
          }
          const payload = data.data ?? data;
          const access = payload.access_token ?? payload.token;
          const refresh = payload.refresh_token;
          if (!access) throw new Error('Token no recibido del servidor');

          localStorage.setItem(ACCESS_KEY, access);
          localStorage.setItem(ACCESS_EXP, String(Date.now() + ACCESS_TTL));
          if (refresh) {
            localStorage.setItem(REFRESH_KEY, refresh);
            localStorage.setItem(REFRESH_EXP, String(Date.now() + REFRESH_TTL));
          }
          clearAttempts();
          window.location.href = redirect;
        } catch (err) {
          showError(err.message);
          btn.disabled = isLocked();
          btnText.textContent = isLocked() ? 'Bloqueado' : 'Iniciar Sesión';
        }
      });

      // Si ya hay token válido, redirige automáticamente.
      const existing = localStorage.getItem(ACCESS_KEY);
      const exp = Number(localStorage.getItem(ACCESS_EXP) ?? 0);
      if (existing && existing !== 'undefined' && exp > Date.now()) {
        window.location.href = redirect;
      }
    </script>
  </body>
</html>
