---
// AdminTopbar v3.0 — breadcrumbs, búsqueda global, notif, user menu.
interface Props {
  title: string;
  section: string;
  breadcrumb?: { name: string; url?: string }[];
}
const { title, section, breadcrumb = [] } = Astro.props;

const SECTIONS: Record<string, string> = {
  dashboard: 'Dashboard',
  inbox: 'Bandeja de Leads',
  pipeline: 'Pipeline',
  leads: 'Leads',
  quotes: 'Cotizaciones',
  clients: 'Clientes',
  cms: 'CMS',
  media: 'Biblioteca de Medios',
  reports: 'Reportes',
  team: 'Equipo',
  settings: 'Configuración',
  login: 'Acceso',
};
const bc = SECTIONS[section] ?? 'Dashboard';
---

<header id="topbar">
  <div class="topbar-left">
    <div class="breadcrumb" aria-label="Breadcrumb">
      <a href="/admin">Admin</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">{bc}</span>
      {breadcrumb.map((b) => (
        <>
          <span class="bc-sep">/</span>
          {b.url ? <a href={b.url}>{b.name}</a> : <span class="bc-current">{b.name}</span>}
        </>
      ))}
    </div>
    <h1 class="topbar-title">{title}</h1>
  </div>

  <div class="topbar-actions">
    <div class="search-box" role="search">
      <span class="search-icon" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </span>
      <input type="search" placeholder="Buscar leads, clientes, cotizaciones…" aria-label="Buscar" />
      <kbd>/</kbd>
    </div>
    <button class="icon-btn" aria-label="Notificaciones">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span class="notif-dot"></span>
    </button>
    <a href="/admin/settings" class="user-chip" title="admin@guardman.cl">
      <span class="user-avatar">AD</span>
      <span class="user-name">Admin</span>
    </a>
    <a href="/" target="_blank" class="icon-btn" aria-label="Ver sitio" title="Ver sitio público">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </div>
</header>

<style>
  #topbar {
    grid-area: topbar;
    background: var(--surface-3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: center;
    padding: 0 20px;
    gap: 16px;
    z-index: 20;
  }
  .topbar-left { flex: 1; min-width: 0; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--fg-dim);
    margin-bottom: 2px;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; transition: color 150ms ease; }
  .breadcrumb a:hover { color: var(--fg); }
  .breadcrumb .bc-sep { opacity: 0.5; }
  .breadcrumb .bc-current { color: var(--fg-muted); font-weight: 500; }
  .topbar-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 0 10px;
    width: 280px;
    transition: border-color 150ms ease;
  }
  .search-box:focus-within { border-color: var(--color-accent); }
  .search-icon { color: var(--fg-dim); display: grid; place-items: center; }
  .search-box input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--fg);
    font-size: 13px;
    padding: 8px 8px;
    font-family: inherit;
    outline: none;
    min-width: 0;
  }
  .search-box input::placeholder { color: var(--fg-dim); }
  .search-box kbd {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 4px;
    font-size: 10px;
    color: var(--fg-dim);
    padding: 1px 5px;
    font-family: var(--font-mono);
  }

  .icon-btn {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    display: grid;
    place-items: center;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .icon-btn:hover {
    background: var(--surface-2);
    border-color: rgba(255,255,255,0.06);
    color: var(--fg);
  }
  .notif-dot {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 7px;
    height: 7px;
    background: var(--color-error);
    border-radius: 50%;
    border: 2px solid var(--surface-3);
  }

  .user-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px 4px 4px;
    background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 999px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .user-chip:hover { border-color: rgba(255,255,255,0.1); }
  .user-avatar {
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, var(--color-accent), #1d4ed8);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 10px;
    font-weight: 700;
    color: #fff;
  }
  .user-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--fg);
  }

  @media (max-width: 1024px) {
    .search-box { width: 200px; }
  }
  @media (max-width: 768px) {
    .search-box { display: none; }
    .user-name { display: none; }
  }
</style>
