---
// PageHero — Standardized hero block for inner pages.
// v5.2 — Replaces the dozens of inline-styled `<section class="hero">` /
// `<section class="hub-hero">` / `<section class="detail-hero">` variants
// with a single, token-driven component.
//
// Props:
//   variant  : 'light' | 'dark' | 'split' | 'detail' | 'compact'
//   badge    : optional eyebrow text
//   badgeIcon: icon name for the badge (default 'shield')
//   title    : h1 text
//   subtitle : p text
//   ctas     : [{ text, href, variant: 'primary'|'outline'|'ghost' }]
//   image    : optional src for split variant
//   imageAlt : alt for the image
import Icon from './Icon.astro';

interface CTA {
  text: string;
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  icon?: string;
}

interface Props {
  variant?: 'light' | 'dark' | 'split' | 'detail' | 'compact';
  badge?: string;
  badgeIcon?: string;
  title: string;
  subtitle?: string;
  ctas?: CTA[];
  image?: string;
  imageAlt?: string;
  stats?: { value: string; label: string }[];
  dataOdId?: string;
}

const {
  variant = 'light',
  badge,
  badgeIcon = 'shield',
  title,
  subtitle,
  ctas = [],
  image,
  imageAlt = '',
  stats = [],
  dataOdId = 'hero',
} = Astro.props;

const btnClass = (v: CTA['variant'] = 'primary') =>
  `btn ${v === 'primary' ? 'btn-primary' : v === 'outline' ? 'btn-outline-light' : 'btn-ghost'} btn-lg`;
---

<section class:list={['gm-hero', `gm-hero--${variant}`]} data-od-id={dataOdId}>
  <div class="container">
    {variant === 'split' ? (
      <div class="gm-hero-grid">
        <div class="gm-hero-content">
          {badge && (
            <div class="hero-badge">
              <Icon name={badgeIcon} size={14} />
              {badge}
            </div>
          )}
          <h1>{title}</h1>
          {subtitle && <p class="hero-sub" set:html={subtitle} />}
          {ctas.length > 0 && (
            <div class="hero-ctas">
              {ctas.map((c) => (
                <a href={c.href} class={btnClass(c.variant)}>
                  {c.icon && <Icon name={c.icon} size={16} />}
                  {c.text}
                </a>
              ))}
            </div>
          )}
          {stats.length > 0 && (
            <div class="hero-stats">
              {stats.map((s) => (
                <div>
                  <div class="hero-stat-value">{s.value}</div>
                  <div class="hero-stat-label">{s.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
        {image && (
          <div class="gm-hero-visual">
            <div class="hero-product">
              <img src={image} alt={imageAlt} loading="eager" decoding="async" onerror="this.style.display='none'" />
            </div>
          </div>
        )}
      </div>
    ) : (
      <div class="gm-hero-inner">
        {badge && (
          <div class="hero-badge">
            <Icon name={badgeIcon} size={14} />
            {badge}
          </div>
        )}
        <h1>{title}</h1>
        {subtitle && <p class="hero-sub" set:html={subtitle} />}
        {ctas.length > 0 && (
          <div class="hero-ctas">
            {ctas.map((c) => (
              <a href={c.href} class={btnClass(c.variant)}>
                {c.icon && <Icon name={c.icon} size={16} />}
                {c.text}
              </a>
            ))}
          </div>
        )}
        {stats.length > 0 && (
          <div class="hero-stats">
            {stats.map((s) => (
              <div>
                <div class="hero-stat-value">{s.value}</div>
                <div class="hero-stat-label">{s.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</section>
